{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urisys.io/schemas/uripack-markpact.schema.json",
  "title": "UriPack Markpact",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "capabilities"],
  "properties": {
    "apiVersion": { "const": "urisys.io/v1" },
    "kind": { "const": "UriPack" },
    "metadata": {
      "type": "object",
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string" },
        "language": { "type": "string", "enum": ["python", "javascript", "js"] }
      }
    },
    "description": { "type": "string" },
    "scheme": { "type": "string" },
    "schemes": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "uri", "kind", "operation", "handler"],
        "properties": {
          "id": { "type": "string" },
          "uri": { "type": "string" },
          "kind": { "type": "string", "enum": ["command", "query"] },
          "operation": { "type": "string" },
          "handler": { "type": "string" },
          "side_effects": { "type": "boolean" },
          "approval": { "type": "string", "enum": ["required", "not_required"] }
        }
      }
    },
    "policy": { "type": "object" },
    "runtime": { "type": "object" },
    "dependencies": { "type": "object" }
  }
}

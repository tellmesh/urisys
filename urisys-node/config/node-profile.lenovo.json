{
  "profile_id": "urisys-node-lenovo",
  "node_id": "lenovo",
  "screen": {
    "default_backend": "auto",
    "output_dir": "data/screens"
  },
  "him": {
    "driver": "ydotool"
  },
  "forwards": [
    {
      "scheme": "browser",
      "endpoint": "http://127.0.0.1:8792",
      "patterns": [
        "browser://{session}/query/status",
        "browser://{session}/page/command/open",
        "browser://{session}/page/query/dom",
        "browser://{session}/page/command/screenshot",
        "browser://{session}/form/command/submit"
      ]
    },
    {
      "scheme": "imgl",
      "endpoint": "http://127.0.0.1:8219",
      "patterns": [
        "imgl://{host}/image/latest/query/layout",
        "imgl://{host}/image/latest/command/execute"
      ]
    },
    {
      "scheme": "vql",
      "endpoint": "http://127.0.0.1:8220",
      "patterns": [
        "vql://{host}/ui/latest/query/detect",
        "vql://{host}/ui/latest/query/compare"
      ]
    }
  ],
  "policy": {
    "require_pairing": false,
    "require_approval_for": [
      "him.*",
      "kvm.task.*",
      "screen.*.capture*",
      "mail.message.send",
      "mail.message.publish_post",
      "office.document.export_pdf",
      "browser.form.submit",
      "browser.page.open"
    ]
  },
  "office": {
    "driver": "mock",
    "output_dir": "data/office"
  },
  "mail": {
    "driver": "mock",
    "mailpit_api": "http://127.0.0.1:8025/api/v1",
    "smtp_host": "127.0.0.1",
    "smtp_port": 1025
  }
}
